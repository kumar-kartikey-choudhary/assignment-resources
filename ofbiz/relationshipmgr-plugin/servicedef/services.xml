<services xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://ofbiz.apache.org/dtds/services.xsd">

        <description>Relationshipmgr CRUD Services using Entity-Auto</description>

        <!-- ========================================== -->
        <!-- 1. Party Services                          -->
        <!-- ========================================== -->

        <!-- Creates the supertype Party and auto-generates the partyId -->
        <service name="createRmParty" default-entity-name="RmParty" engine="entity-auto" invoke="create" auth="true">
                <description>Create a base Party and auto-generate partyId</description>
                <auto-attributes mode="IN" include="pk" optional="true"/>
                <auto-attributes mode="IN" include="nonpk" optional="true"/>
                <!-- We mark partyId as INOUT because we want to allow custom partyId if provided -->
                <override name="partyId" mode="INOUT" optional="true"/>
        </service>

        <!-- Create Party Unified -->
        <service name="createRmPartyUnified" engine="groovy"
                 location="component://relationshipmgr/groovyScripts/CreateRmPartyUnified.groovy" invoke="createRmPartyUnified" auth="true">
                <description>Create standard Party (Person, Organization or Base) with optional custom partyId</description>
                <attribute type="String" mode="IN" name="partyId" optional="true"/>
                <attribute type="String" mode="IN" name="partyTypeId" optional="false"/>
                <attribute type="String" mode="IN" name="firstName" optional="true"/>
                <attribute type="String" mode="IN" name="lastName" optional="true"/>
                <attribute type="Timestamp" mode="IN" name="birthDate" optional="true"/>
                <attribute type="String" mode="IN" name="organizationName" optional="true"/>
                <attribute type="String" mode="OUT" name="partyId" optional="true"/>
        </service>

        <!-- Creates RmPerson. The caller provides the partyId created from createRmParty -->
        <service name="createRmPerson" default-entity-name="RmPerson" engine="entity-auto" invoke="create" auth="true">
                <description>Create a Person record linked to a Party</description>
                <auto-attributes mode="IN" include="pk" optional="false"/>
                <auto-attributes mode="IN" include="nonpk" optional="true"/>
        </service>

        <!-- Creates RmOrganization. The caller provides the partyId created from createRmParty -->
        <service name="createRmOrganization" default-entity-name="RmOrganization" engine="entity-auto" invoke="create" auth="true">
                <description>Create an Organization record linked to a Party</description>
                <auto-attributes mode="IN" include="pk" optional="false"/>
                <auto-attributes mode="IN" include="nonpk" optional="true"/>
        </service>

        <!-- ========================================== -->
        <!-- 2. Role Assignment Service                 -->
        <!-- ========================================== -->
        <service name="createRmPartyRole" default-entity-name="RmPartyRole" engine="entity-auto" invoke="create" auth="true">
                <description>Assign a Role to a Party</description>
                <auto-attributes mode="IN" include="pk" optional="false"/>
        </service>

        <!-- ========================================== -->
        <!-- 3. Contact Mechanism Services              -->
        <!-- ========================================== -->

        <!-- Creates the base ContactMech and auto-generates contactMechId -->
        <service name="createRmContactMech" default-entity-name="RmContactMech" engine="entity-auto" invoke="create" auth="true">
                <description>Create standard Contact Mechanism</description>
                <auto-attributes mode="IN" include="pk" optional="true"/>
                <auto-attributes mode="IN" include="nonpk" optional="true"/>
                <override name="contactMechId" mode="OUT"/>
        </service>

        <!-- Creates the Postal Address subtype -->
        <service name="createRmPostalAddress" default-entity-name="RmPostalAddress" engine="entity-auto" invoke="create" auth="true">
                <description>Create Postal Address linked to ContactMech</description>
                <auto-attributes mode="IN" include="pk" optional="false"/>
                <auto-attributes mode="IN" include="nonpk" optional="true"/>
        </service>

        <!-- Creates the Telecom Number subtype -->
        <service name="createRmTelecomNumber" default-entity-name="RmTelecomNumber" engine="entity-auto" invoke="create" auth="true">
                <description>Create Telecom Number linked to ContactMech</description>
                <auto-attributes mode="IN" include="pk" optional="false"/>
                <auto-attributes mode="IN" include="nonpk" optional="true"/>
        </service>

        <!-- ========================================== -->
        <!-- 4. Party Contact Association Services      -->
        <!-- ========================================== -->

        <!-- Binds a Party to a ContactMech. Auto-generates current timestamp for fromDate -->
        <service name="createRmPartyContactMech" default-entity-name="RmPartyContactMech" engine="entity-auto" invoke="create" auth="true">
                <description>Bind Contact Mechanism to Party</description>
                <auto-attributes mode="IN" include="pk" optional="true"/>
                <auto-attributes mode="IN" include="nonpk" optional="true"/>
                <override name="fromDate" mode="INOUT" optional="true"/>
        </service>

</services>