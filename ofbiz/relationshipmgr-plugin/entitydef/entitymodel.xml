<entitymodel xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:noNamespaceSchemaLocation="https://ofbiz.apache.org/dtds/entitymodel.xsd">

    <title>Entity Model of Relationship Manager Component</title>
    <description>Models for Party, Person, Organization, PartyRoles, and Contact Mechanisms</description>


    <!-- Party Type Definition -->
    <entity entity-name="RmPartyType" package-name="org.apache.ofbiz.relationshipmgr" title="RM Party Type Entity">
        <field name="partyTypeId" type="id"></field>
        <field name="parentTypeId" type="id"></field>
        <field name="description" type="description"></field>
        <prim-key field="partyTypeId"/>
        <relation type="one" fk-name="FK_RM_PTY_TYP_PAR" title="Parent" rel-entity-name="RmPartyType">
            <key-map field-name="parentTypeId" rel-field-name="partyTypeId"/>
        </relation>
    </entity>



    <!-- ========================================== -->
    <!-- 1. Party & Subtypes (Person, Organization) -->
    <!-- ========================================== -->
    <entity entity-name="RmParty" package-name="org.apache.ofbiz.relationshipmgr" title="RM Party Supertype Entity">
        <field name="partyId" type="id"></field>
        <field name="partyTypeId" type="id"></field>
        <prim-key field="partyId"/>
        <relation type="one" fk-name="FK_RM_PARTY_TYPE" rel-entity-name="RmPartyType">
            <key-map field-name="partyTypeId"/>
        </relation>
    </entity>

    <entity entity-name="RmPerson" package-name="org.apache.ofbiz.relationshipmgr" title="RM Person Subtype Entity">
        <field name="partyId" type="id"></field>
        <field name="firstName" type="name"></field>
        <field name="lastName" type="name"></field>
        <field name="birthDate" type="date"></field>
        <prim-key field="partyId"/>
        <relation type="one" fk-name="FK_RM_PERS_PARTY" rel-entity-name="RmParty">
            <key-map field-name="partyId"/>
        </relation>
    </entity>

    <entity entity-name="RmOrganization" package-name="org.apache.ofbiz.relationshipmgr" title="RM Organization Subtype Entity">
        <field name="partyId" type="id"></field>
        <field name="organizationName" type="name"></field>
        <prim-key field="partyId"/>
        <relation type="one" fk-name="FK_RM_ORG_PARTY" rel-entity-name="RmParty">
            <key-map field-name="partyId"/>
        </relation>
    </entity>

    <!-- ========================================== -->
    <!-- 2. Roles (Intersection/Association models) -->
    <!-- ========================================== -->
    <entity entity-name="RmRoleType" package-name="org.apache.ofbiz.relationshipmgr" title="RM Role Type Entity">
        <field name="roleTypeId" type="id"></field>
        <field name="description" type="description"></field>
        <prim-key field="roleTypeId"/>
    </entity>

    <entity entity-name="RmPartyRole" package-name="org.apache.ofbiz.relationshipmgr" title="RM Party Role Intersection Entity">
        <field name="partyId" type="id"></field>
        <field name="roleTypeId" type="id"></field>
        <prim-key field="partyId"/>
        <prim-key field="roleTypeId"/>
        <relation type="one" fk-name="FK_RM_PROLE_PARTY" rel-entity-name="RmParty">
            <key-map field-name="partyId"/>
        </relation>
        <relation type="one" fk-name="FK_RM_PROLE_TYPE" rel-entity-name="RmRoleType">
            <key-map field-name="roleTypeId"/>
        </relation>
    </entity>

    <!-- ========================================== -->
    <!-- 3. Contact Mechanism & Subtypes            -->
    <!-- ========================================== -->
    <entity entity-name="RmContactMechType" package-name="org.apache.ofbiz.relationshipmgr" title="RM Contact Mech Type Entity">
        <field name="contactMechTypeId" type="id"></field>
        <field name="description" type="description"></field>
        <prim-key field="contactMechTypeId"/>
    </entity>

    <entity entity-name="RmContactMechPurposeType" package-name="org.apache.ofbiz.relationshipmgr" title="RM Contact Mech Purpose Type Entity">
        <field name="contactMechPurposeTypeId" type="id"></field>
        <field name="description" type="description"></field>
        <prim-key field="contactMechPurposeTypeId"/>
    </entity>

    <entity entity-name="RmContactMech" package-name="org.apache.ofbiz.relationshipmgr" title="RM Contact Mech Supertype Entity">
        <field name="contactMechId" type="id"></field>
        <field name="contactMechTypeId" type="id"></field>
        <field name="infoString" type="value"></field>
        <prim-key field="contactMechId"/>
        <relation type="one" fk-name="FK_RM_CMECH_TYPE" rel-entity-name="RmContactMechType">
            <key-map field-name="contactMechTypeId"/>
        </relation>
    </entity>

    <entity entity-name="RmPostalAddress" package-name="org.apache.ofbiz.relationshipmgr" title="RM Postal Address Subtype Entity">
        <field name="contactMechId" type="id"></field>
        <field name="address1" type="value"></field>
        <field name="address2" type="value"></field>
        <field name="city" type="name"></field>
        <field name="stateProvinceGeoId" type="id"></field>
        <field name="postalCode" type="value"></field>
        <field name="countryGeoId" type="id"></field>
        <prim-key field="contactMechId"/>
        <relation type="one" fk-name="FK_RM_PADDR_CMECH" rel-entity-name="RmContactMech">
            <key-map field-name="contactMechId"/>
        </relation>
    </entity>

    <entity entity-name="RmTelecomNumber" package-name="org.apache.ofbiz.relationshipmgr" title="RM Telecom Number Subtype Entity">
        <field name="contactMechId" type="id"></field>
        <field name="countryCode" type="value"></field>
        <field name="areaCode" type="value"></field>
        <field name="contactNumber" type="value"></field>
        <prim-key field="contactMechId"/>
        <relation type="one" fk-name="FK_RM_TEL_CMECH" rel-entity-name="RmContactMech">
            <key-map field-name="contactMechId"/>
        </relation>
    </entity>

    <!-- ========================================== -->
    <!-- 4. Party Contact Association & Purposes    -->
    <!-- ========================================== -->
    <entity entity-name="RmPartyContactMech" package-name="org.apache.ofbiz.relationshipmgr" title="RM Party Contact Mech Temporal Association Entity">
        <field name="partyId" type="id"></field>
        <field name="contactMechId" type="id"></field>
        <field name="fromDate" type="date-time"></field>
        <field name="thruDate" type="date-time"></field>
        <prim-key field="partyId"/>
        <prim-key field="contactMechId"/>
        <prim-key field="fromDate"/>
        <relation type="one" fk-name="FK_RM_PCMECH_PARTY" rel-entity-name="RmParty">
            <key-map field-name="partyId"/>
        </relation>
        <relation type="one" fk-name="FK_RM_PCMECH_CMECH" rel-entity-name="RmContactMech">
            <key-map field-name="contactMechId"/>
        </relation>
    </entity>

    <entity entity-name="RmPartyContactMechPurpose" package-name="org.apache.ofbiz.relationshipmgr" title="RM Party Contact Mech Purpose Entity">
        <field name="partyId" type="id"></field>
        <field name="contactMechId" type="id"></field>
        <field name="contactMechPurposeTypeId" type="id"></field>
        <field name="fromDate" type="date-time"></field>
        <field name="thruDate" type="date-time"></field>
        <prim-key field="partyId"/>
        <prim-key field="contactMechId"/>
        <prim-key field="contactMechPurposeTypeId"/>
        <prim-key field="fromDate"/>
        <relation type="one" fk-name="FK_RM_PCMPURP_PCMECH" rel-entity-name="RmPartyContactMech">
            <key-map field-name="partyId"/>
            <key-map field-name="contactMechId"/>
            <key-map field-name="fromDate"/>
        </relation>
        <relation type="one" fk-name="FK_RM_PCMPURP_TYPE" rel-entity-name="RmContactMechPurposeType">
            <key-map field-name="contactMechPurposeTypeId"/>
        </relation>
    </entity>
</entitymodel>