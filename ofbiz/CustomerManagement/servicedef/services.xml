<services xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="https://ofbiz.apache.org/dtds/services.xsd">
    <description>Customer Management Services</description>
    <vendor>OFBiz</vendor>
    <version>1.0</version>

    <!-- ============================================================
         findCustomer — searches FindCustomerView with optional filters
         ============================================================ -->
    <service name="findCustomer" engine="groovy"
             location="component://CustomerManagement/src/main/groovy/org/apache/ofbiz/customermgmt/FindCustomer.groovy"
             invoke="findCustomer" auth="true" export="true">
        <description>Find customers by optional partial/case-insensitive filters</description>
        <attribute name="partyId"        type="String" mode="IN" optional="true"/>
        <attribute name="firstName"      type="String" mode="IN" optional="true"/>
        <attribute name="lastName"       type="String" mode="IN" optional="true"/>
        <attribute name="emailAddress"   type="String" mode="IN" optional="true"/>
        <attribute name="contactNumber"  type="String" mode="IN" optional="true"/>
        <attribute name="address1"       type="String" mode="IN" optional="true"/>
        <attribute name="city"           type="String" mode="IN" optional="true"/>
        <!-- OUT -->
        <attribute name="customerList"   type="java.util.List" mode="OUT" optional="false"/>
    </service>

    <!-- ============================================================
         createCustomer — creates Party/Person + email ContactMech
         Uniqueness: email with contactMechPurposeTypeId=PRIMARY_EMAIL
         ============================================================ -->
    <service name="createCustomer" engine="groovy"
             location="component://CustomerManagement/src/main/groovy/org/apache/ofbiz/customermgmt/CreateCustomer.groovy"
             invoke="createCustomer" auth="true" export="true">
        <description>Create a new customer (Party+Person). Email (PRIMARY_EMAIL) must be unique.</description>
        <!-- Required -->
        <attribute name="emailAddress"   type="String" mode="IN" optional="false"/>
        <attribute name="firstName"      type="String" mode="IN" optional="false"/>
        <attribute name="lastName"       type="String" mode="IN" optional="false"/>
        <!-- Optional -->
        <attribute name="salutation"     type="String" mode="IN" optional="true"/>
        <attribute name="middleName"     type="String" mode="IN" optional="true"/>
        <attribute name="contactNumber"  type="String" mode="IN" optional="true"/>
        <attribute name="areaCode"       type="String" mode="IN" optional="true"/>
        <attribute name="countryCode"    type="String" mode="IN" optional="true"/>
        <attribute name="address1"       type="String" mode="IN" optional="true"/>
        <attribute name="address2"       type="String" mode="IN" optional="true"/>
        <attribute name="city"           type="String" mode="IN" optional="true"/>
        <attribute name="postalCode"     type="String" mode="IN" optional="true"/>
        <attribute name="countryGeoId"   type="String" mode="IN" optional="true"/>
        <!-- OUT -->
        <attribute name="partyId"        type="String" mode="OUT" optional="false"/>
    </service>

    <!-- ============================================================
         updateCustomer — updates postal address and/or phone
         Identified by emailAddress (PRIMARY_EMAIL)
         ============================================================ -->
    <service name="updateCustomer" engine="groovy"
             location="component://CustomerManagement/src/main/groovy/org/apache/ofbiz/customermgmt/UpdateCustomer.groovy"
             invoke="updateCustomer" auth="true" export="true">
        <description>Update a customer's postal address and/or phone number. Identified by email.</description>
        <!-- Required (unique identifier) -->
        <attribute name="emailAddress"   type="String" mode="IN" optional="false"/>
        <!-- Optional update fields -->
        <attribute name="firstName"      type="String" mode="IN" optional="true"/>
        <attribute name="lastName"       type="String" mode="IN" optional="true"/>
        <attribute name="contactNumber"  type="String" mode="IN" optional="true"/>
        <attribute name="areaCode"       type="String" mode="IN" optional="true"/>
        <attribute name="countryCode"    type="String" mode="IN" optional="true"/>
        <attribute name="address1"       type="String" mode="IN" optional="true"/>
        <attribute name="address2"       type="String" mode="IN" optional="true"/>
        <attribute name="city"           type="String" mode="IN" optional="true"/>
        <attribute name="postalCode"     type="String" mode="IN" optional="true"/>
        <attribute name="countryGeoId"   type="String" mode="IN" optional="true"/>
    </service>

    <!-- ============================================================
         createCustomerRelationship — creates PartyRelationship
         ============================================================ -->
    <service name="createCustomerRelationship" engine="groovy"
             location="component://CustomerManagement/src/main/groovy/org/apache/ofbiz/customermgmt/CreateCustomerRelationship.groovy"
             invoke="createCustomerRelationship" auth="true" export="true">
        <description>Establish a PartyRelationship between two parties</description>
        <attribute name="partyIdFrom"          type="String" mode="IN" optional="false"/>
        <attribute name="partyIdTo"            type="String" mode="IN" optional="false"/>
        <attribute name="partyRelationshipTypeId" type="String" mode="IN" optional="false"/>
        <attribute name="roleTypeIdFrom"       type="String" mode="IN" optional="true"/>
        <attribute name="roleTypeIdTo"         type="String" mode="IN" optional="true"/>
        <attribute name="statusId"             type="String" mode="IN" optional="true"/>
        <!-- OUT -->
        <attribute name="fromDate"             type="java.sql.Timestamp" mode="OUT" optional="false"/>
    </service>

    <!-- ============================================================
         updateCustomerRelationship — updates an existing PartyRelationship
         ============================================================ -->
    <service name="updateCustomerRelationship" engine="groovy"
             location="component://CustomerManagement/src/main/groovy/org/apache/ofbiz/customermgmt/UpdateCustomerRelationship.groovy"
             invoke="updateCustomerRelationship" auth="true" export="true">
        <description>Update an existing PartyRelationship (statusId, thruDate, comments)</description>
        <attribute name="partyIdFrom"             type="String"             mode="IN" optional="false"/>
        <attribute name="partyIdTo"               type="String"             mode="IN" optional="false"/>
        <attribute name="partyRelationshipTypeId" type="String"             mode="IN" optional="false"/>
        <attribute name="roleTypeIdFrom"          type="String"             mode="IN" optional="false"/>
        <attribute name="roleTypeIdTo"            type="String"             mode="IN" optional="false"/>
        <attribute name="fromDate"                type="java.sql.Timestamp" mode="IN" optional="false"/>
        <attribute name="statusId"                type="String"             mode="IN" optional="true"/>
        <attribute name="thruDate"                type="java.sql.Timestamp" mode="IN" optional="true"/>
        <attribute name="comments"                type="String"             mode="IN" optional="true"/>
    </service>

</services>