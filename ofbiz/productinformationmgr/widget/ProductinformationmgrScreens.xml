<screens xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns="http://ofbiz.apache.org/Widget-Screen" xsi:schemaLocation="http://ofbiz.apache.org/Widget-Screen http://ofbiz.apache.org/dtds/widget-screen.xsd">

    <!-- 1. Products Tab (Dashboard) -->
    <screen name="main">
        <section>
            <actions>
                <set field="headerItem" value="main"/>
                <set field="titleProperty" value="ProductinformationmgrApplication"/>
            </actions>
            <widgets>
                <decorator-screen name="ProductinformationmgrCommonDecorator" location="${parameters.mainDecoratorLocation}">
                    <decorator-section name="body">
                        <!-- Top: List Products -->
                        <container style="row">
                            <container style="col-md-12">
                                <screenlet title="Products Catalog Dashboard">
                                    <include-form name="ListPimProducts" location="component://productinformationmgr/widget/ProductinformationmgrForms.xml"/>
                                </screenlet>
                            </container>
                        </container>

                        <!-- Bottom: Forms for Creating Product, Price, Content -->
                        <container style="row" style-custom="display: flex; gap: 20px; margin-top: 20px; flex-wrap: wrap;">
                            <container style="col-md-4" style-custom="flex: 1; min-width: 300px;">
                                <screenlet title="Create New Product">
                                    <include-form name="AddPimProduct" location="component://productinformationmgr/widget/ProductinformationmgrForms.xml"/>
                                </screenlet>
                            </container>
                        </container>
                    </decorator-section>
                </decorator-screen>
            </widgets>
        </section>
    </screen>

    <!-- 2. Product Categories Tab -->
    <screen name="productCategories">
        <section>
            <actions>
                <set field="headerItem" value="productCategories"/>
                <set field="titleProperty" value="ProductinformationmgrApplication"/>
            </actions>
            <widgets>
                <decorator-screen name="ProductinformationmgrCommonDecorator" location="${parameters.mainDecoratorLocation}">
                    <decorator-section name="body">
                        <!-- Top: List Categories & Member Assignments -->
                        <container style="row" style-custom="display: flex; gap: 20px; flex-wrap: wrap;">
                            <container style="col-md-6" style-custom="flex: 1; min-width: 350px;">
                                <screenlet title="Product Categories">
                                    <include-form name="ListPimProductCategories" location="component://productinformationmgr/widget/ProductinformationmgrForms.xml"/>
                                </screenlet>
                            </container>
                            <container style="col-md-6" style-custom="flex: 1; min-width: 350px;">
                                <screenlet title="Category Members (Product Assignments)">
                                    <include-form name="ListPimProductCategoryMembers" location="component://productinformationmgr/widget/ProductinformationmgrForms.xml"/>
                                </screenlet>
                            </container>
                        </container>

                        <!-- Bottom: Forms for Category Management -->
                        <container style="row" style-custom="display: flex; gap: 20px; margin-top: 20px; flex-wrap: wrap;">
                            <container style="col-md-6" style-custom="flex: 1; min-width: 350px;">
                                <screenlet title="Create New Category">
                                    <include-form name="AddPimProductCategory" location="component://productinformationmgr/widget/ProductinformationmgrForms.xml"/>
                                </screenlet>
                            </container>
                            <container style="col-md-6" style-custom="flex: 1; min-width: 350px;">
                                <screenlet title="Assign Product to Category">
                                    <include-form name="AddPimProductCategoryMember" location="component://productinformationmgr/widget/ProductinformationmgrForms.xml"/>
                                </screenlet>
                            </container>
                        </container>
                    </decorator-section>
                </decorator-screen>
            </widgets>
        </section>
    </screen>

    <!-- 3. Product Features Tab -->
    <screen name="productFeatures">
        <section>
            <actions>
                <set field="headerItem" value="productFeatures"/>
                <set field="titleProperty" value="ProductinformationmgrApplication"/>
            </actions>
            <widgets>
                <decorator-screen name="ProductinformationmgrCommonDecorator" location="${parameters.mainDecoratorLocation}">
                    <decorator-section name="body">
                        <!-- Top: List Features & Feature Applications -->
                        <container style="row" style-custom="display: flex; gap: 20px; flex-wrap: wrap;">
                            <container style="col-md-6" style-custom="flex: 1; min-width: 350px;">
                                <screenlet title="Product Features">
                                    <include-form name="ListPimProductFeatures" location="component://productinformationmgr/widget/ProductinformationmgrForms.xml"/>
                                </screenlet>
                            </container>
                            <container style="col-md-6" style-custom="flex: 1; min-width: 350px;">
                                <screenlet title="Feature Applications (Applied Features)">
                                    <include-form name="ListPimProductFeatureAppls" location="component://productinformationmgr/widget/ProductinformationmgrForms.xml"/>
                                </screenlet>
                            </container>
                        </container>

                        <!-- Bottom: Forms for Feature Management -->
                        <container style="row" style-custom="display: flex; gap: 20px; margin-top: 20px; flex-wrap: wrap;">
                            <container style="col-md-6" style-custom="flex: 1; min-width: 350px;">
                                <screenlet title="Create New Feature">
                                    <include-form name="AddPimProductFeature" location="component://productinformationmgr/widget/ProductinformationmgrForms.xml"/>
                                </screenlet>
                            </container>
                            <container style="col-md-6" style-custom="flex: 1; min-width: 350px;">
                                <screenlet title="Apply Feature to Product">
                                    <include-form name="AddPimProductFeatureAppl" location="component://productinformationmgr/widget/ProductinformationmgrForms.xml"/>
                                </screenlet>
                            </container>
                        </container>
                    </decorator-section>
                </decorator-screen>
            </widgets>
        </section>
    </screen>

    <!-- 4. Product Associations & Specs Tab -->
    <screen name="productAssocs">
        <section>
            <actions>
                <set field="headerItem" value="productAssocs"/>
                <set field="titleProperty" value="ProductinformationmgrApplication"/>
            </actions>
            <widgets>
                <decorator-screen name="ProductinformationmgrCommonDecorator" location="${parameters.mainDecoratorLocation}">
                    <decorator-section name="body">
                        <!-- Top: List Associations & Dimensions -->
                        <container style="row" style-custom="display: flex; gap: 20px; flex-wrap: wrap;">
                            <container style="col-md-6" style-custom="flex: 1; min-width: 350px;">
                                <screenlet title="Product Associations (e.g. Variants &amp; Package Components)">
                                    <include-form name="ListPimProductAssocs" location="component://productinformationmgr/widget/ProductinformationmgrForms.xml"/>
                                </screenlet>
                            </container>
                        </container>
                    </decorator-section>
                </decorator-screen>
            </widgets>
        </section>
    </screen>

    <!-- 5. Pricing Tab -->
    <screen name="pricing">
        <section>
            <actions>
                <set field="headerItem" value="pricing"/>
                <set field="titleProperty" value="ProductinformationmgrApplication"/>
            </actions>
            <widgets>
                <decorator-screen name="ProductinformationmgrCommonDecorator" location="${parameters.mainDecoratorLocation}">
                    <decorator-section name="body">
                        <container style="row" style-custom="display: flex; gap: 20px; flex-wrap: wrap;">
                            <container style="col-md-6" style-custom="flex: 1; min-width: 350px;">
                                <screenlet title="Product Prices">
                                    <include-form name="ListPimProductPrices" location="component://productinformationmgr/widget/ProductinformationmgrForms.xml"/>
                                </screenlet>
                                <screenlet title="Create Product Price">
                                    <include-form name="AddPimProductPrice" location="component://productinformationmgr/widget/ProductinformationmgrForms.xml"/>
                                </screenlet>

                                <!-- <screenlet title="Price Changes">
                                    <include-form name="ListPimProductPriceChanges" location="component://productinformationmgr/widget/ProductinformationmgrForms.xml"/>
                                </screenlet>
                                <screenlet title="Create Price Change">
                                    <include-form name="AddPimProductPriceChange" location="component://productinformationmgr/widget/ProductinformationmgrForms.xml"/>
                                </screenlet> -->
                            </container>
                            <container style="col-md-6" style-custom="flex: 1; min-width: 350px;">
                                <screenlet title="Price Types">
                                    <include-form name="ListPimProductPriceTypes" location="component://productinformationmgr/widget/ProductinformationmgrForms.xml"/>
                                </screenlet>
                                <screenlet title="Create Price Type">
                                    <include-form name="AddPimProductPriceType" location="component://productinformationmgr/widget/ProductinformationmgrForms.xml"/>
                                </screenlet>

                                <screenlet title="Price Purposes">
                                    <include-form name="ListPimProductPricePurposes" location="component://productinformationmgr/widget/ProductinformationmgrForms.xml"/>
                                </screenlet>
                                <screenlet title="Create Price Purpose">
                                    <include-form name="AddPimProductPricePurpose" location="component://productinformationmgr/widget/ProductinformationmgrForms.xml"/>
                                </screenlet>

                                <screenlet title="Payment Method Types">
                                    <include-form name="ListPimProductPaymentMethodTypes" location="component://productinformationmgr/widget/ProductinformationmgrForms.xml"/>
                                </screenlet>
                                <screenlet title="Create Payment Method Type">
                                    <include-form name="AddPimProductPaymentMethodType" location="component://productinformationmgr/widget/ProductinformationmgrForms.xml"/>
                                </screenlet>
                            </container>
                        </container>
                    </decorator-section>
                </decorator-screen>
            </widgets>
        </section>
    </screen>

</screens>