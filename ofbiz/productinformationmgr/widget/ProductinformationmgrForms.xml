        </field>
        <field name="description" title="Description">
            <display/>
        </field>
    </form>
    <form name="AddPimProductPricePurpose" type="single" target="createPimProductPricePurpose" title="Add Price Purpose" style="basic-form">
        <field name="productPricePurposeId" title="Price Purpose ID">
            <text size="20"/>
        </field>
        <field name="description" title="Description">
            <text size="40"/>
        </field>
        <field name="submitButton" title="Add">
            <submit button-type="button"/>
        </field>
    </form>

    <!-- 11. PimProductPaymentMethodType Forms -->
    <form name="ListPimProductPaymentMethodTypes" type="list" list-name="paymentMethodTypes" paginate-target="pricing" style="basic-table hover-bar">
        <actions>
            <entity-condition entity-name="PimProductPaymentMethodType" list="paymentMethodTypes">
                <order-by field-name="productId"/>
            </entity-condition>
        </actions>
        <field name="productId" title="Product ID">
            <display/>
        </field>
        <field name="paymentMethodTypeId" title="Payment Method Type ID">
            <display/>
        </field>
        <field name="productPricePurposeId" title="Price Purpose">
            <display/>
        </field>
        <field name="fromDate" title="From Date">
            <display/>
        </field>
        <field name="sequenceNum" title="Sequence Num">
            <display/>
        </field>
    </form>
    <form name="AddPimProductPaymentMethodType" type="single" target="createPimProductPaymentMethodType" title="Add Payment Method Type" style="basic-form">
        <field name="productId" title="Product" widget-style="required">
            <drop-down allow-empty="false">
                <entity-options entity-name="PimProduct" description="${productName} [${productId}]"/>
            </drop-down>
        </field>
        <field name="paymentMethodTypeId" title="Payment Method Type ID">
            <text size="20"/>
        </field>
        <field name="productPricePurposeId" title="Price Purpose" widget-style="required">
            <drop-down allow-empty="false">
                <entity-options entity-name="PimProductPricePurpose" description="${description}"/>
            </drop-down>
        </field>
        <field name="fromDate" title="From Date">
            <date-time/>
        </field>
        <field name="sequenceNum" title="Sequence Num">
            <text size="10"/>
        </field>
        <field name="submitButton" title="Add">
            <submit button-type="button"/>
        </field>
    </form>


</forms>