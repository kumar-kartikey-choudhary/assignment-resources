                <parameter param-name="productAssocTypeEnumId"/>
                <parameter param-name="fromDate"/>
            </hyperlink>
        </field> -->
    </form>

    <form name="AddPimProductAssoc" type="single" target="createPimProductAssoc" title="Create Product Association" style="basic-form">
        <field name="productId" title="From Product" widget-style="required">
            <drop-down allow-empty="false">
                <entity-options entity-name="PimProduct" description="${productName} [${productId}]"/>
            </drop-down>
        </field>
        <field name="toProductId" title="To Product" widget-style="required">
            <drop-down allow-empty="false">
                <entity-options entity-name="PimProduct" description="${productName} [${productId}]"/>
            </drop-down>
        </field>
        <field name="productAssocTypeId" title="Association Type" widget-style="required">
            <drop-down allow-empty="false">
                <entity-options entity-name="PimProductAssocType" description="${description}"/>
            </drop-down>
        </field>
        <field name="fromDate" title="From Date">
            <date-time/>
        </field>
        <field name="submitButton" title="Associate Products">
            <submit button-type="button"/>
        </field>
    </form>

    <!-- 9. PimProductPriceType Forms -->
    <form name="ListPimProductPriceTypes" type="list" list-name="priceTypes" paginate-target="pricing" style="basic-table hover-bar">
        <actions>
            <entity-condition entity-name="PimProductPriceType" list="priceTypes">
                <order-by field-name="productPriceTypeId"/>
            </entity-condition>
        </actions>
        <field name="productPriceTypeId" title="Price Type ID">
            <display/>
        </field>
        <field name="description" title="Description">
            <display/>
        </field>
    </form>
    <form name="AddPimProductPriceType" type="single" target="createPimProductPriceType" title="Add Price Type" style="basic-form">
        <field name="productPriceTypeId" title="Price Type ID">
            <text size="20"/>
        </field>
        <field name="description" title="Description">
            <text size="40"/>
        </field>
        <field name="submitButton" title="Add">
            <submit button-type="button"/>
        </field>
    </form>

    <!-- 10. PimProductPricePurpose Forms -->
    <form name="ListPimProductPricePurposes" type="list" list-name="pricePurposes" paginate-target="pricing" style="basic-table hover-bar">
        <actions>
            <entity-condition entity-name="PimProductPricePurpose" list="pricePurposes">
                <order-by field-name="productPricePurposeId"/>
